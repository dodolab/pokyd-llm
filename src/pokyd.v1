BYTE VYBER_PLUGINU(void) {

#define POCET_PLUGINU 10
#define ZACATEK_PLUGINU 7

BYTE pozice=ZACATEK_PLUGINU,puvpozx=wherex(),puvpozy=wherey(),pomoc,pomoc2,sipkapozice=1;
DWORD blikaninazvu=0,pohybsipky=0,cassetric;
WORD pomoc3;
BYTE pluginy[POCET_PLUGINU][9]={"CookEdit","Cas","Had","Honicka","Kalkul","NajdiMe","NoKomar","Palba","Pismena","Silnice"};
BYTE komentar[70],navrathodnota=0,cookinfo,znak;

  ZACATEK:
  SMAZOBRAZOVKU(1); SMAZKURZOR(); jeli_nastaveni=2;
  PIS(29,1," Pokyd - vyber pluginu ",14+16);
  PIS(21,5," Vyber si plugin, ktery chces spustit: ",16+15);
  PIS(34,24," Esc - zpet ",12+(4<<4));
  ZAPISCAS();
  VRATDATA(3); pomoc3=0;
  for (pomoc=ZACATEK_PLUGINU; pomoc < ZACATEK_PLUGINU+POCET_PLUGINU; pomoc++) {
    pomoc2=0;
    while (dlouhe[pomoc3] != '\r') {
      komentar[pomoc2]=dlouhe[pomoc3];
      pomoc2++; pomoc3++;
     }
    komentar[pomoc2]=0; pomoc3+=2;		//vynechani znaku '\n'
    PIS(16,pomoc,komentar,10);
   }
  PIS(2,19,"Dalsi funkce:",13);
  ZVYRAZNOVAC(10,20,"Spustit jiny program",1);
  ZVYRAZNOVAC(41,20,"Vymazat soubory s hovorem",1);
  ZVYRAZNOVAC(17,21,"Kydani pocitacu",1);
  ZVYRAZNOVAC(50,21,"Zformatovat harddisk",2);

  VYBER:
  for (pomoc=ZACATEK_PLUGINU; pomoc < ZACATEK_PLUGINU+POCET_PLUGINU; pomoc++) {
    PIS(2,pomoc,pomoc == pozice ? "ÍÍÍ" : "    ",15);
    PIS(7,pomoc,pluginy[pomoc-ZACATEK_PLUGINU],pomoc == pozice ? 15 : 3);
   }

  ZACATECNIK("Tady si muzes vybrat nejaky plugin, napr. hru ci jiny program a spustit ho.",31);
  ZACATECNIK("Pohybujes se sipkama. Specialni akce (dole) vyberes zvyraznenou klavesou.",32);

  GETCH:
  cassetric=time(NULL);
  while (kbhit() == 0) {
    if (pocetsetricvterin != 0 && (cassetric+pocetsetricvterin) < time(NULL)) {
SETRIC: SETRIC_OBRAZOVKY(); goto ZACATEK;
     }
    if (CAS18() < pohybsipky) {				//pulnoc
      pohybsipky=CAS18(); blikaninazvu=pohybsipky; }
    if (CAS18() > pohybsipky+5) {			//pokyb sipky
      PIS(2,pozice,sipkapozice == 1 ? "ÍÍÍ" : " Í ",15);
      pohybsipky=CAS18();
      if (sipkapozice == 1) sipkapozice=0; else sipkapozice=1;
     }
    if (CAS18() > blikaninazvu+8) {			//blikani nazvu
      PIS(7,pozice,pluginy[pozice-ZACATEK_PLUGINU],(rand()%6)+10);
      blikaninazvu=CAS18();
     }
    if (SETRIC_KLAVESA() == 1) cassetric=time(NULL);
    KONTROLA_UTNUTI(); CAS(0);
   }

  znak=getch();
  if (znak >= '0' && znak <= '9') {
    if (znak == '0') pozice=ZACATEK_PLUGINU+9;
    else pozice=znak-'1'+ZACATEK_PLUGINU;
    goto SPUST;
   }
  else switch(znak) {
    case 0: znak=getch(); if (znak >=120 && znak <=129) {
      pozice=znak-120+ZACATEK_PLUGINU; goto SPUST;
     } else switch(znak) {
      case 59: HELPF1(13); goto ZACATEK;		//F1
      case 64: goto SETRIC;				//F6
      case 68: goto KONEC;				//F10
      case 72:						//nahoru
	if (pozice > ZACATEK_PLUGINU) { pozice--; goto VYBER; }
        goto GETCH;
      case 80: 						//dolu
	if (pozice < ZACATEK_PLUGINU+POCET_PLUGINU-1) { pozice++; goto VYBER; }
        goto GETCH;
      default: goto GETCH;
     }
    case '\r': case ' ':				//enter, mezera
SPUST:  SOUBOR("PLUGINY\\"); strcat(soubor,pluginy[pozice-ZACATEK_PLUGINU]); strcat(soubor,".exe");
      if (findfirst(soubor,&ffblk,6) == -1) {		//plugin neexistuje
        HLASKA("Ha! Plugin neexistuje! Porid si funkcni verzi a ne tuhle vykuchanou hruzu!",4);
        goto VYBER;
       }
      SMAZOBRAZOVKU(1); textcolor(7); cprintf("Spoustim plugin %s...\r",pluginy[pozice-ZACATEK_PLUGINU]); jeli_nastaveni=0;
      if (strcmp(pluginy[pozice-ZACATEK_PLUGINU],"CookEdit") == 0) {
	ZAPIS_INFORMACE_O_VETACH(3,0); cookinfo=1; SOUBOR("PLUGINY\\CookEdit.exe");
       }
      else cookinfo=0;
      SPUST(soubor,0,1); jeli_nastaveni=2; SMAZKURZOR();
      if (cookinfo == 1) CTI_INFORMACE_O_VETACH();
      blikaninazvu=CAS18(); pohybsipky=blikaninazvu; goto ZACATEK;
    case 0x1B: goto KONEC;
    case 's': case 'S': navrathodnota=1; goto KONEC;
    case 'v': case 'V': navrathodnota=2; goto KONEC;
    case 'k': case 'K': navrathodnota=3; goto KONEC;
    case 'f': case 'F': navrathodnota=4; goto KONEC;
    default: goto GETCH;
   }
  KONEC: NASTAVSPRAVNYMOD();
  gotoxy(puvpozx,puvpozy); jeli_nastaveni=1; NASTAVKURZOR();
  return(navrathodnota);
 }

BYTE SETRIC_KLAVESA(void) {
  if (kbhit() != 0) return(1);
  if ((bioskey(2)&15) != 0) return(1);
  memset(&pokyd_regs, 0, sizeof(pokyd_regs));
  _AX = 3;
  geninterrupt(0x33);
  if (_BX != 0) return(1);
  return(0);
 }

void SETRIC_POPOSUN_OBRAZOVKU(void) {
BYTE pozice,pomocne;
WORD cisloradku,poz1,poz2;
  gettext(1,1,80,25,dlouhe);
  for (cisloradku=0; cisloradku < 4000; cisloradku+=160) {

    pomocne=dlouhe[cisloradku];
    for (pozice=0; pozice < 160-2; pozice+=2)
     dlouhe[pozice+cisloradku]=dlouhe[pozice+2+cisloradku];
    dlouhe[158+cisloradku]=pomocne;

    pomocne=(dlouhe[1+cisloradku]&15)+(dlouhe[159+cisloradku]&240);
    for (pozice=1; pozice < 160-2; pozice+=2)
     dlouhe[pozice+cisloradku]=(dlouhe[pozice+2+cisloradku]&15)+(dlouhe[pozice+cisloradku]&240);
    dlouhe[159+cisloradku]=pomocne;
   }
  for (pozice=0; pozice < 30; pozice++) {
    poz1=((rand()%25)*160)+158; poz2=((rand()%25)*160)+158; pomocne=dlouhe[poz1];
    dlouhe[poz1]=dlouhe[poz2]; dlouhe[poz2]=pomocne;
    poz1++; poz2++; pomocne=dlouhe[poz1];
    dlouhe[poz1]=dlouhe[poz2]; dlouhe[poz2]=pomocne;
   }

  puttext(1,1,80,25,dlouhe);
 }

void SETRIC_OBRAZOVKY(void) {
BYTE barva1,pozicey1,pozicex2,pozicey2,hvezda=0,pokyd=0,typhvezdy;
signed char pozicex1;
BYTE zacatek=0,mazani,cas,rychlost=4,puvr,puvg,puvb,br=0,bg=0,bb=0,pr,pg,pb;
DWORD cas18;
  SMAZOBRAZOVKU(0); SMAZKURZOR(); NASTAVPOKYDFONT();
  _AX = 0x1003; _BL = 0; geninterrupt(0x10);		//zakaz blikani
  _AX = 0x1015; _BX = 1; geninterrupt(0x10);
  puvr=_DH; puvg=_CH; puvb=_CL;
  cas18=CAS18();
START:
  while (kbhit() == 0 && (bioskey(2)&15) == 0) {
    if (hvezda == 0) {
      HVEZDA1:
      pozicex1=(rand()%80)+1; pozicey1=(rand()%25)+1; barva1=(rand()%14)+2;
      gotoxy(pozicex1,pozicey1);
      _AL = CTIZNAK(); if (_AL != ' ') goto HVEZDA1;
      switch(rand()%3) {
        case 0: typhvezdy='.'; break;
        case 1: typhvezdy=''; break;
        case 2: typhvezdy='*'; break;
       }
      NAPISZNAK(typhvezdy,(CTIBARVU()&240)+barva1);
      hvezda=1;
     }
    else if (hvezda++ == 5) hvezda=0;

    if (zacatek == 100) {
      for (mazani=0; mazani < 3; mazani++) {
        gotoxy((rand()%80)+1,(rand()%25)+1);	//mazani hvezd
        NAPISZNAK(' ',CTIBARVU()&240);
       }
     }

    if (pokyd == 0) {
      if (zacatek == 100 && (rand()%10) == 0) {
	pozicex2=(rand()%(79-OBRAZEK_POKYDU_X+1))+1; pozicey2=(rand()%(25-OBRAZEK_POKYDU_Y+1))+1;
	BARVY:
	pr=rand()%3; pg=rand()%3; pb=rand()%3;
	if (pr != 2 && pg != 2 && pb != 2) goto BARVY;
	br=0; bg=0; bb=0;
	OBRAZEK_POKYDU(pozicex2,pozicey2,1,1); pokyd=1;
       }
     }
    else if (pokyd < 33) {
      br+=pr; bg+=pg; bb+=pb;
     }
    else if (pokyd < 70) {
      if (br < 15) { if (br != 0) br--; }	//vyhlazenejsi zmizeni
      else br-=pr;
      if (bg < 15) { if (bg != 0) bg--; }
      else bg-=pg;
      if (bb < 15) { if (bb != 0) bb--; }
      else bb-=pb;
     }
    else if (pokyd == 70) {
      OBRAZEK_POKYDU(pozicex2,pozicey2,0,1);
     }
    NASTAVBARVU(br,bg,bb,1);

    if (zacatek == 100 && pokyd > 0) {
      pokyd++; if (pokyd == 90) pokyd=0;
     }

    while (cas18 == CAS18()) {
      KONTROLA_UTNUTI();
      if (SETRIC_KLAVESA() == 1) goto KONEC;
     }
    cas18=CAS18();
    SETRIC_POPOSUN_OBRAZOVKU();
    pozicex1--; if (pozicex1 < 1) pozicex1+=80;	//posun hvezd
    if (zacatek < 100) zacatek++;
   }
  KONEC:
  if (kbhit() != 0) _CL = getch();
  if (_CL == '+') { rychlost--; goto START; }
  else if (_CL == '-') { rychlost++; goto START; }
  if (kbhit() != 0) CTIKLAVESU();
  NASTAVBARVU(puvr,puvg,puvb,1);
  _AX = 0x1003; _BL = 1; geninterrupt(0x10);		//povol blikani
 }
