# Copy to bridge/.env and set at least OPENAI_API_KEY.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=512

# Host-side TCP listen port (Node bridge). Pokyd uses POKYD_LLM_PORT or this value by default.
BRIDGE_PORT=8765
BRIDGE_BIND=0.0.0.0
BRIDGE_TIMEOUT_MS=30000

# Optional: BRIDGE_VERBOSE=1
