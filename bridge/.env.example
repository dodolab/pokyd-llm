# Required: your OpenAI secret key
OPENAI_API_KEY=sk-...

# Model to use (gpt-4o-mini is fast and cheap; gpt-4o for better quality)
OPENAI_MODEL=gpt-4o-mini

# Max tokens per OpenAI API response (keep low — Pokyd's display buffer is 3980 chars)
OPENAI_MAX_TOKENS=512

# TCP port and bind address for the DOS client
BRIDGE_PORT=8765
BRIDGE_BIND=0.0.0.0

# Optional: override the Pokyd persona system prompt
# OPENAI_SYSTEM_PROMPT=You are a helpful assistant.

# Max milliseconds to wait for an OpenAI response before returning an error to DOS
BRIDGE_TIMEOUT_MS=30000
